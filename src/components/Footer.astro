---
const base = import.meta.env.BASE_URL;
---
<footer class="w-full bg-canvas border-t border-hairline mt-auto font-sans">
  <div class="max-w-[1400px] mx-auto px-6 md:px-8 py-12 md:py-16 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-6 gap-8 md:gap-12">
    <!-- Col 1: Brand -->
    <div class="col-span-1 sm:col-span-2 md:col-span-2 flex flex-col gap-4">
      <div class="flex items-center gap-2">
        <svg viewBox="0 0 100 100" class="w-4 h-4 fill-ink" aria-hidden="true">
          <!-- Top-left outer and inner squares -->
          <rect x="0" y="0" width="35" height="35" rx="4" fill="none" stroke="currentColor" stroke-width="8"/>
          <rect x="10" y="10" width="15" height="15" rx="1" fill="currentColor"/>
          <!-- Top-right outer and inner squares -->
          <rect x="65" y="0" width="35" height="35" rx="4" fill="none" stroke="currentColor" stroke-width="8"/>
          <rect x="75" y="10" width="15" height="15" rx="1" fill="currentColor"/>
          <!-- Bottom-left outer and inner squares -->
          <rect x="0" y="65" width="35" height="35" rx="4" fill="none" stroke="currentColor" stroke-width="8"/>
          <rect x="10" y="75" width="15" height="15" rx="1" fill="currentColor"/>
          <!-- Bottom-right pixel clusters -->
          <rect x="65" y="65" width="12" height="12" rx="1" fill="currentColor"/>
          <rect x="83" y="65" width="17" height="12" rx="1" fill="currentColor"/>
          <rect x="65" y="83" width="12" height="17" rx="1" fill="currentColor"/>
          <rect x="83" y="83" width="17" height="17" rx="2" fill="currentColor"/>
        </svg>
        <span class="font-semibold text-sm tracking-tight text-ink">QR&nbsp;Guy</span>
      </div>
      <p class="text-xs text-body leading-relaxed max-w-xs">
        A premium, developer-grade QR creation workspace. Generate, style, download, and copy vector QR codes client-side, 100% privately.
      </p>
      <div class="flex items-center gap-2 mt-2">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-link opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-link"></span>
        </span>
        <span class="text-[11px] font-mono text-body font-medium">All Systems Operational</span>
      </div>
    </div>

    <!-- Col 2: Generator -->
    <div class="flex flex-col gap-3">
      <h3 class="text-xs font-mono font-medium text-ink uppercase tracking-wider">Generator</h3>
      <ul class="flex flex-col gap-2">
        <li><a href={`${base}#generator`} class="text-xs text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-1.5 -mx-1.5">Link to QR</a></li>
        <li><a href={`${base}#generator`} class="text-xs text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-1.5 -mx-1.5">Number to QR</a></li>
        <li><a href={`${base}#generator`} class="text-xs text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-1.5 -mx-1.5">Code to QR</a></li>
        <li><a href={`${base}#generator`} class="text-xs text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-1.5 -mx-1.5">Branded Designs</a></li>
      </ul>
    </div>

    <!-- Col 3: Tools -->
    <div class="flex flex-col gap-3">
      <h3 class="text-xs font-mono font-medium text-ink uppercase tracking-wider">Tools</h3>
      <ul class="flex flex-col gap-2">
        <li><a href={`${base}#scanner`} class="text-xs text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-1.5 -mx-1.5">Scan QR Code</a></li>
        <li><a href={`${base}#history`} class="text-xs text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-1.5 -mx-1.5">History Log</a></li>
        <li><a href={`${base}#developer`} class="text-xs text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-1.5 -mx-1.5">API Docs</a></li>
        <li><a href="https://github.com/Aftab016/qr-guy.com" target="_blank" rel="noreferrer" class="text-xs text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-1.5 -mx-1.5">GitHub Repository</a></li>
      </ul>
    </div>

    <!-- Col 4: Company -->
    <div class="flex flex-col gap-3">
      <h3 class="text-xs font-mono font-medium text-ink uppercase tracking-wider">Company</h3>
      <ul class="flex flex-col gap-2">
        <li><a href={`${base}about-us`} class="text-xs text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-1.5 -mx-1.5">About Us</a></li>
        <li><a href={`${base}contact-us`} class="text-xs text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-1.5 -mx-1.5">Contact Us</a></li>
      </ul>
    </div>

    <!-- Col 5: Legal -->
    <div class="flex flex-col gap-3">
      <h3 class="text-xs font-mono font-medium text-ink uppercase tracking-wider">Legal</h3>
      <ul class="flex flex-col gap-2">
        <li><a href={`${base}privacy-policy`} class="text-xs text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-1.5 -mx-1.5">Privacy Policy</a></li>
        <li><a href={`${base}terms-and-conditions`} class="text-xs text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-1.5 -mx-1.5">Terms & Conditions</a></li>
        <li class="pt-2 border-t border-hairline mt-1">
          <span class="text-[10px] text-mute font-mono block">100% Client-Side</span>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom Divider -->
  <div class="border-t border-hairline bg-canvas-soft py-6">
    <div class="max-w-[1400px] mx-auto px-6 md:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="text-[11px] text-mute font-mono">
        © {new Date().getFullYear()} QR&nbsp;Guy (qrguy.com). Built with privacy-focused local client security. <a href="https://github.com/Aftab016/qr-guy.com" target="_blank" rel="noreferrer" class="underline hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded px-1 -mx-1">GitHub</a>
      </div>
      <div class="flex items-center gap-4">
        <span class="text-[11px] text-mute flex items-center gap-1.5 font-mono">
          <span>Designed with Precision</span>
          <span class="w-1 h-1 rounded-full bg-mute"></span>
          <span>Open Source</span>
        </span>
      </div>
    </div>
  </div>
</footer>
