---
---
<section class="relative w-full py-16 md:py-24 px-6 md:px-8 border-b border-hairline overflow-hidden bg-canvas">
  <!-- Premium Animated Mesh Gradient Background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none -z-10" aria-hidden="true">
    <!-- Blue/Teal Blob -->
    <div class="absolute top-[-30%] left-[-10%] w-[60%] h-[70%] rounded-full bg-link/15 dark:bg-link/10 blur-[100px] md:blur-[130px] animate-mesh-1"></div>
    <!-- Violet/Pink Blob -->
    <div class="absolute top-[-10%] right-[-10%] w-[55%] h-[60%] rounded-full bg-violet/15 dark:bg-violet/8 blur-[100px] md:blur-[140px] animate-mesh-2"></div>
    <!-- Pink/Magenta Blob -->
    <div class="absolute bottom-[-20%] left-[10%] w-[45%] h-[55%] rounded-full bg-highlight-pink/15 dark:bg-highlight-pink/8 blur-[90px] md:blur-[120px] animate-mesh-3"></div>
    <!-- Mint/Cyan Blob -->
    <div class="absolute top-[20%] left-[30%] w-[40%] h-[50%] rounded-full bg-cyan/15 dark:bg-cyan/8 blur-[90px] md:blur-[120px] animate-mesh-1"></div>
  </div>

  <div class="max-w-[1200px] mx-auto flex flex-col items-center text-center">
    <!-- Monochrome Announcement Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border border-hairline bg-canvas-soft-2 text-[11px] font-mono text-body">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-cyan"></span>
      Introducing QR Guy 1.0. Zero Paywalls.
    </div>

    <!-- Vercel-style Large Display Headline -->
    <h1 class="font-sans font-semibold text-4xl sm:text-5xl md:text-6xl text-ink leading-[1.05] tracking-[-1.5px] sm:tracking-[-2px] md:tracking-[-2.8px] max-w-3xl mb-6 select-none">
      Create and design premium QR codes. Instantly.
    </h1>

    <!-- Supporting Lead Paragraph -->
    <p class="font-sans text-sm sm:text-base md:text-lg text-body leading-relaxed max-w-2xl mb-8 font-light">
      A developer-grade QR creation workstation. Choose custom shapes, linear/radial gradients, embed custom logos, and export vector SVG codes. Generates 100% client-side in your browser.
    </p>

    <!-- Call to Actions -->
    <div class="flex flex-col sm:flex-row items-center gap-4">
      <a 
        href="#generator" 
        class="inline-flex items-center justify-center h-12 px-8 text-sm font-semibold rounded-pill bg-primary text-on-primary hover:opacity-90 active:scale-98 transition-all shadow-level-3 cursor-pointer w-full sm:w-auto"
      >
        Start Creating
      </a>
      <a 
        href="#scanner" 
        class="inline-flex items-center justify-center h-12 px-8 text-sm font-semibold rounded-pill bg-canvas text-ink border border-hairline hover:bg-canvas-soft-2 active:scale-98 transition-all cursor-pointer w-full sm:w-auto"
      >
        Scan QR Code
      </a>
    </div>

    <!-- Secondary Nav Links for SEO & Quick Navigation -->
    <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-2 mt-10 pt-6 border-t border-hairline w-full max-w-lg">
      <a 
        href="/about-us" 
        class="text-xs font-medium text-body hover:text-ink transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-2 py-0.5"
      >
        About Us
      </a>
      <span class="w-1 h-1 rounded-full bg-hairline-strong/60" aria-hidden="true"></span>
      <a 
        href="/contact-us" 
        class="text-xs font-medium text-body hover:text-ink transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-2 py-0.5"
      >
        Contact Us
      </a>
      <span class="w-1 h-1 rounded-full bg-hairline-strong/60" aria-hidden="true"></span>
      <a 
        href="/privacy-policy" 
        class="text-xs font-medium text-body hover:text-ink transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-2 py-0.5"
      >
        Privacy Policy
      </a>
      <span class="w-1 h-1 rounded-full bg-hairline-strong/60" aria-hidden="true"></span>
      <a 
        href="/terms-and-conditions" 
        class="text-xs font-medium text-body hover:text-ink transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-sm px-2 py-0.5"
      >
        Terms & Conditions
      </a>
    </div>
  </div>
</section>
