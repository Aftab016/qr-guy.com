---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout 
  title="Internal Server Error — QR Guy" 
  description="We encountered an unexpected error on QR Guy. Please try again later."
  robots="noindex, nofollow"
>
  <Header />

  <main class="flex-grow relative bg-canvas flex items-center justify-center py-20 md:py-32 px-6 md:px-8 font-sans overflow-hidden">
    <!-- Premium Error/Warning Mesh Gradient Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none -z-10" aria-hidden="true">
      <div class="absolute top-[10%] left-[-10%] w-[55%] h-[60%] rounded-full bg-error/10 dark:bg-error/5 blur-[100px] md:blur-[130px] animate-mesh-1"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[60%] h-[60%] rounded-full bg-warning/10 dark:bg-warning/5 blur-[100px] md:blur-[130px] animate-mesh-3"></div>
    </div>

    <div class="max-w-[500px] w-full text-center space-y-8 relative z-10">
      <!-- Error Code Display -->
      <div class="relative inline-flex items-center justify-center">
        <!-- Outer glowing element with error colors -->
        <div class="absolute -inset-4 rounded-full bg-gradient-to-r from-error/20 to-warning/20 blur-xl opacity-75 dark:opacity-50"></div>
        
        <!-- Big Number -->
        <span class="relative text-8xl md:text-9xl font-bold font-mono tracking-tighter text-transparent bg-clip-text bg-gradient-to-br from-error-deep to-warning-deep dark:from-error dark:to-warning select-none">
          500
        </span>
      </div>

      <!-- Copy -->
      <div class="space-y-3">
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-2 rounded-full border border-hairline bg-canvas-soft-2 text-[11px] font-mono text-body">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-error animate-pulse"></span>
          Error: Server_Execution_Crash
        </div>
        <h1 class="text-3xl font-semibold text-ink tracking-tight leading-tight">
          Internal Server Error.
        </h1>
        <p class="text-sm text-body leading-relaxed max-w-sm mx-auto">
          Something went wrong on our server. If you keep seeing this message, please report it via our GitHub Issue Tracker.
        </p>
      </div>

      <!-- Quick Links/Buttons -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center items-center pt-2">
        <a 
          href={base} 
          id="btn-500-home"
          class="inline-flex items-center justify-center px-6 h-11 text-xs font-semibold rounded-md bg-primary text-on-primary hover:opacity-90 active:scale-98 transition-[transform,opacity] duration-150 cursor-pointer w-full sm:w-auto shadow-level-2"
        >
          Go Back Home
        </a>
        <a 
          href="https://github.com/Aftab016/qr-guy.com/issues/new" 
          target="_blank"
          rel="noopener noreferrer"
          id="btn-500-github"
          class="inline-flex items-center justify-center px-6 h-11 text-xs font-semibold rounded-md border border-hairline bg-canvas hover:bg-canvas-soft-2 text-ink active:scale-98 transition-[transform,background-color] duration-150 cursor-pointer w-full sm:w-auto"
        >
          Report Issue
        </a>
      </div>

      <!-- Decorative code block -->
      <div class="border border-hairline rounded-lg bg-canvas-soft-2/50 backdrop-blur-sm p-4 font-mono text-[11px] text-mute text-left max-w-xs mx-auto shadow-level-1">
        <div class="flex items-center gap-1.5 pb-2 mb-2 border-b border-hairline">
          <span class="w-2.5 h-2.5 rounded-full bg-hairline-strong"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-hairline-strong"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-hairline-strong"></span>
          <span class="text-[9px] text-mute ml-1">stack_trace</span>
        </div>
        <p class="text-body"><span class="text-error">Error:</span> Fail to parse request handler</p>
        <p class="text-[10px] mt-1 opacity-70">at Astro.Handler.execute (server.js:42:15)</p>
        <p class="text-[10px] opacity-70">at process.processTicksAndRejections (node:internal/process/task_queues:95:5)</p>
        <p class="text-[10px] text-mute mt-1">Status: HTTP/2 500 Internal Server Error</p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
