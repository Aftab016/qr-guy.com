---
import { seo } from "../utils/seo.js";
const content = seo.seoContent;
---

{
  content && (
    <section
      class="w-full bg-canvas border-t border-hairline py-12 px-6 md:px-8 font-sans"
      id="seo-workspace-docs"
    >
      <div class="max-w-[1200px] mx-auto">
        <details class="group border border-hairline rounded-lg bg-canvas-soft overflow-hidden transition-all duration-300 [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer select-none hover:bg-canvas-soft-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/20 transition-colors">
            <div class="flex flex-col gap-1 text-left">
              <span class="text-xs font-mono font-medium text-mute uppercase tracking-wider">
                {content.subtitle}
              </span>
              <h2 class="text-lg font-semibold text-ink tracking-tight">
                {content.title}
              </h2>
            </div>
            <div class="flex items-center justify-center w-8 h-8 rounded-full border border-hairline bg-canvas text-ink group-open:rotate-180 transition-transform duration-300">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="w-4 h-4"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
            </div>
          </summary>

          <div class="p-6 md:p-8 border-t border-hairline bg-canvas text-sm text-body leading-relaxed space-y-6">
            {content.paragraphs &&
              content.paragraphs.map((p) => <p set:html={p} />)}

            {content.columns && content.columns.length > 0 && (
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-4">
                {content.columns.map((col) => (
                  <div class="space-y-4">
                    <h3 class="text-base font-semibold text-ink">
                      {col.title}
                    </h3>
                    {col.text && <p set:html={col.text} />}
                    {col.list && col.list.length > 0 && (
                      <ul class="space-y-2 list-disc list-inside text-xs text-mute pl-2">
                        {col.list.map((item) => (
                          <li set:html={item} />
                        ))}
                      </ul>
                    )}
                    {col.footerText && <p set:html={col.footerText} />}
                  </div>
                ))}
              </div>
            )}

            {content.conclusionTitle && (
              <div class="pt-4 border-t border-hairline space-y-4">
                <h3 class="text-base font-semibold text-ink">
                  {content.conclusionTitle}
                </h3>
                {content.conclusionText && (
                  <p set:html={content.conclusionText} />
                )}
                {content.conclusionCards &&
                  content.conclusionCards.length > 0 && (
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-xs font-mono">
                      {content.conclusionCards.map((card) => (
                        <div class="p-4 rounded border border-hairline bg-canvas-soft-2">
                          <span class="block font-semibold text-ink mb-1">
                            {card.number} / {card.title}
                          </span>
                          <p class="text-[11px] leading-relaxed text-mute">
                            {card.description}
                          </p>
                        </div>
                      ))}
                    </div>
                  )}
                {content.conclusionFooter && (
                  <p set:html={content.conclusionFooter} />
                )}
              </div>
            )}
          </div>
        </details>
      </div>
    </section>
  )
}
