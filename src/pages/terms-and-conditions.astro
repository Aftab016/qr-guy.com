---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCanonical } from '../utils/seo.js';
---

<Layout 
  title="Terms & Conditions — QR Guy" 
  description="Read the terms and conditions for using QR Guy. Open-source MIT licence guidelines, client-side utility disclaimer, and fair usage terms."
  canonicalUrl={getCanonical('/terms-and-conditions')}
>
  <Header />

  <main class="flex-grow relative bg-canvas py-16 md:py-24 px-6 md:px-8 font-sans">
    <!-- Premium Mesh Gradient Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none -z-10" aria-hidden="true">
      <div class="absolute top-[-30%] right-[-10%] w-[55%] h-[60%] rounded-full bg-violet/10 dark:bg-violet/5 blur-[100px] md:blur-[130px] animate-mesh-1"></div>
      <div class="absolute bottom-[-15%] left-[-15%] w-[60%] h-[60%] rounded-full bg-link/10 dark:bg-link/5 blur-[100px] md:blur-[120px] animate-mesh-2"></div>
    </div>

    <div class="max-w-[800px] mx-auto">
      <!-- Tag / Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border border-hairline bg-canvas-soft-2 text-[11px] font-mono text-body">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-warning"></span>
        Last Updated: June 10, 2026
      </div>

      <!-- Main Heading -->
      <h1 class="text-4xl sm:text-5xl font-semibold text-ink tracking-tight mb-8 leading-[1.1] select-none">
        Terms and Conditions
      </h1>

      <!-- Lead paragraph -->
      <p class="text-lg text-body font-light leading-relaxed mb-12">
        Welcome to QR Guy. By accessing or using this client-side utility workspace, you agree to comply with the terms and conditions outlined below.
      </p>

      <!-- Terms Content Blocks -->
      <div class="space-y-10 text-sm text-body leading-relaxed">
        
        <div class="space-y-3">
          <h2 class="text-lg font-semibold text-ink tracking-tight border-b border-hairline pb-2">1. Use of the Services</h2>
          <p>
            QR Guy is provided entirely free of charge as an open-source, web-based tool. 
          </p>
          <p>
            You are permitted to generate, style, customize, and export QR codes and barcodes for personal, developer, commercial, or packaging purposes. No license fees, account setups, or attribution requirements are enforced for using the generated assets.
          </p>
        </div>

        <div class="space-y-3">
          <h2 class="text-lg font-semibold text-ink tracking-tight border-b border-hairline pb-2">2. Open Source & Licensing</h2>
          <p>
            The software, excluding specific branding marks and assets, is licensed under the terms of the <strong>MIT License</strong>. You can access the complete source code, fork the project, and host your own instances in compliance with the MIT License terms.
          </p>
        </div>

        <div class="space-y-3">
          <h2 class="text-lg font-semibold text-ink tracking-tight border-b border-hairline pb-2">3. Disclaimer of Warranties</h2>
          <div class="p-4 rounded border border-warning-soft bg-warning-soft/30 dark:bg-warning-deep/10 text-xs text-warning-deep dark:text-warning leading-relaxed font-mono">
            THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE SOFTWARE.
          </div>
          <p class="text-[13px] text-body">
            You acknowledge that QR and barcode generation and scanning algorithms are dependent on local client computing performance, browser compatibility, camera capture quality, and the accuracy of the characters input by the user.
          </p>
        </div>

        <div class="space-y-3">
          <h2 class="text-lg font-semibold text-ink tracking-tight border-b border-hairline pb-2">4. User Uploaded Content & Logos</h2>
          <p>
            Users are solely responsible for verifying the copyright, licensing, and usage rights of any custom brand logo, trademark, or graphic asset they upload to embed in their QR codes. QR Guy does not inspect, vet, or retain these uploaded assets as the processing happens entirely within the local web browser.
          </p>
        </div>

        <div class="space-y-3">
          <h2 class="text-lg font-semibold text-ink tracking-tight border-b border-hairline pb-2">5. Prohibited Activities</h2>
          <p>
            You agree not to use QR Guy to:
          </p>
          <ul class="list-disc list-inside space-y-1.5 text-xs text-mute pl-2">
            <li>Generate malicious QR codes or barcodes intended to distribute phishing links, malware, or coordinate cyber attacks.</li>
            <li>Attempt to disrupt the static server delivery hosting or overload client delivery channels.</li>
            <li>Embed unlawful or offensive imagery in standard preset designs.</li>
          </ul>
        </div>

        <div class="space-y-3">
          <h2 class="text-lg font-semibold text-ink tracking-tight border-b border-hairline pb-2">6. Limitation of Liability</h2>
          <p>
            Under no circumstances shall the creators or maintainers of QR Guy be liable for any direct, indirect, incidental, special, or consequential damages resulting from the use or inability to use the generator, the scanning app, history logs, or api docs.
          </p>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</Layout>
