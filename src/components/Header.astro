---
---
<header class="sticky top-0 z-40 w-full border-b border-hairline bg-canvas/80 backdrop-blur-md">
  <!-- Top Deck: Brand & Actions -->
  <div class="h-16 flex items-center justify-between px-6 md:px-8 max-w-[1400px] mx-auto w-full">
    <!-- Left: Logo -->
    <div class="flex items-center gap-3">
      <a href="/" class="flex items-center gap-2.5 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20 rounded-md p-1 -m-1" aria-label="QR Guy Home">
        <!-- QR Guy Logo -->
        <div class="relative w-7 h-7 flex items-center justify-center text-ink group-hover:scale-105 transition-transform">
          <svg viewBox="0 0 100 100" class="w-6 h-6 fill-current" aria-hidden="true">
            <!-- Top-left outer and inner squares -->
            <rect x="0" y="0" width="35" height="35" rx="5" fill="none" stroke="currentColor" stroke-width="8"/>
            <rect x="10" y="10" width="15" height="15" rx="1.5" fill="currentColor"/>
            <!-- Top-right outer and inner squares -->
            <rect x="65" y="0" width="35" height="35" rx="5" fill="none" stroke="currentColor" stroke-width="8"/>
            <rect x="75" y="10" width="15" height="15" rx="1.5" fill="currentColor"/>
            <!-- Bottom-left outer and inner squares -->
            <rect x="0" y="65" width="35" height="35" rx="5" fill="none" stroke="currentColor" stroke-width="8"/>
            <rect x="10" y="75" width="15" height="15" rx="1.5" fill="currentColor"/>
            <!-- Bottom-right pixel clusters -->
            <rect x="65" y="65" width="12" height="12" rx="1.5" fill="currentColor"/>
            <rect x="83" y="65" width="17" height="12" rx="1.5" fill="currentColor"/>
            <rect x="65" y="83" width="12" height="17" rx="1.5" fill="currentColor"/>
            <rect x="83" y="83" width="17" height="17" rx="2" fill="currentColor"/>
          </svg>
        </div>
        <span class="font-sans font-bold text-xl tracking-tight text-ink">QR&nbsp;Guy</span>
      </a>
      <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full border border-hairline bg-canvas-soft text-body text-[11px] font-mono font-medium">
        v1.0.0
      </span>
    </div>

    <!-- Right: Actions -->
    <div class="flex items-center gap-3">
      <!-- Theme Toggle Button -->
      <button 
        id="theme-toggle" 
        class="group w-9 h-9 rounded-md flex items-center justify-center text-body hover:text-ink border border-hairline hover:bg-canvas-soft-2 transition-[color,background-color,border-color] duration-200 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20"
        aria-label="Toggle dark mode"
      >
        <!-- Sun icon (shown in light mode) -->
        <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4.5 h-4.5 transition-transform duration-300 group-hover:rotate-12 group-active:scale-90 hidden dark:block" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21M5.22 5.22l1.59 1.59m10.38 10.38l1.59 1.59M12 6.75a5.25 5.25 0 1 0 0 10.5 5.25 5.25 0 0 0 0-10.5ZM3 12h2.25m13.5 0H21M5.22 18.78l1.59-1.59m10.38-10.38l1.59-1.59" />
        </svg>
        <!-- Moon icon (shown in dark mode) -->
        <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4.5 h-4.5 transition-transform duration-300 group-hover:rotate-12 group-active:scale-90 dark:hidden" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
      </button>

      <!-- GitHub Link -->
      <a 
        href="https://github.com/Aftab016/qr-guy.com" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="group w-9 h-9 rounded-md flex items-center justify-center text-body hover:text-ink border border-hairline hover:bg-canvas-soft-2 transition-[color,background-color,border-color] duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink/20"
        aria-label="GitHub Repository"
      >
        <svg class="w-4.5 h-4.5 fill-current transition-transform duration-200 group-hover:scale-110 group-active:scale-95" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
        </svg>
      </a>

      <!-- CTA Button -->
      <button 
        data-action="start-generating" 
        class="hidden sm:inline-flex items-center justify-center px-4 h-9 text-xs font-semibold rounded-md bg-primary text-on-primary hover:opacity-90 active:scale-98 transition-[opacity,transform] duration-200 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 shadow-level-2"
      >
        Start Generating
      </button>
    </div>
  </div>

  <!-- Bottom Deck: Sub-Navigation -->
  <div class="border-t border-hairline w-full bg-canvas/30 py-2">
    <div class="max-w-[1400px] mx-auto px-6 md:px-8 flex items-center overflow-x-auto scrollbar-none">
      <nav class="flex p-1 bg-canvas-soft-2 border border-hairline rounded-lg gap-1" aria-label="Main Navigation" role="tablist">
        <button 
          data-tab-btn="generator" 
          role="tab"
          aria-selected="true"
          class="nav-tab-btn px-4 py-1.5 text-xs sm:text-sm font-medium rounded-md bg-canvas border border-hairline shadow-level-2 text-ink transition-all duration-200 ease-in-out cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/20"
        >
          Generator
        </button>
        <button 
          data-tab-btn="scanner" 
          role="tab"
          aria-selected="false"
          class="nav-tab-btn px-4 py-1.5 text-xs sm:text-sm font-medium rounded-md bg-transparent border border-transparent text-body hover:text-ink hover:bg-canvas/50 transition-all duration-200 ease-in-out cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/20"
        >
          QR & Barcode Scanner
        </button>
        <button 
          data-tab-btn="history" 
          role="tab"
          aria-selected="false"
          class="nav-tab-btn px-4 py-1.5 text-xs sm:text-sm font-medium rounded-md bg-transparent border border-transparent text-body hover:text-ink hover:bg-canvas/50 transition-all duration-200 ease-in-out cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/20 flex items-center gap-1.5"
        >
          <span>History</span>
          <span id="history-badge" class="hidden px-2 py-0.5 text-[10px] font-semibold bg-canvas-soft border border-hairline text-ink rounded-full">0</span>
        </button>
        <button 
          data-tab-btn="developer" 
          role="tab"
          aria-selected="false"
          class="nav-tab-btn px-4 py-1.5 text-xs sm:text-sm font-medium rounded-md bg-transparent border border-transparent text-body hover:text-ink hover:bg-canvas/50 transition-all duration-200 ease-in-out cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/20"
        >
          Developer API
        </button>
      </nav>
    </div>
  </div>
</header>

<script>
  // Client-side theme toggling
  const themeToggle = document.getElementById('theme-toggle') as HTMLButtonElement | null;
  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  }

  // Handle active navigation styling dynamically (SPA behavior)
  const tabButtons = document.querySelectorAll('.nav-tab-btn') as NodeListOf<HTMLButtonElement>;
  
  // Set tab active function
  window.addEventListener('hashchange', updateActiveTab);
  
  function updateActiveTab() {
    const isHome = window.location.pathname === '/' || window.location.pathname === '/index.html' || window.location.pathname === '';
    const hash = window.location.hash.replace('#', '') || (isHome ? 'generator' : '');
    
    tabButtons.forEach(btn => {
      const btnTab = btn.getAttribute('data-tab-btn');
      if (btnTab === hash && hash) {
        btn.classList.add('bg-canvas', 'border-hairline', 'shadow-level-2', 'text-ink');
        btn.classList.remove('bg-transparent', 'border-transparent', 'text-body', 'hover:bg-canvas/50');
        btn.setAttribute('aria-selected', 'true');
      } else {
        btn.classList.remove('bg-canvas', 'border-hairline', 'shadow-level-2', 'text-ink');
        btn.classList.add('bg-transparent', 'border-transparent', 'text-body', 'hover:bg-canvas/50');
        btn.setAttribute('aria-selected', 'false');
      }
    });

    if (hash) {
      // Dispatch a custom event to change visibility of tab containers
      const tabChangeEvent = new CustomEvent('tab-change', { detail: { tab: hash } });
      window.dispatchEvent(tabChangeEvent);
    }
  }

  // Bind tab click handlers
  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.getAttribute('data-tab-btn');
      const isHome = window.location.pathname === '/' || window.location.pathname === '/index.html' || window.location.pathname === '';
      if (!isHome) {
        window.location.href = `/#${tab}`;
      } else {
        window.location.hash = `#${tab}`;
      }
    });
  });

  // Start Generating button handler
  const startBtn = document.querySelector('[data-action="start-generating"]') as HTMLButtonElement | null;
  if (startBtn) {
    startBtn.addEventListener('click', () => {
      const isHome = window.location.pathname === '/' || window.location.pathname === '/index.html' || window.location.pathname === '';
      if (!isHome) {
        window.location.href = '/#generator';
      } else {
        window.location.hash = '#generator';
      }
    });
  }
  
  // Initialize on first load
  updateActiveTab();
</script>

