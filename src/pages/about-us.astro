---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCanonical } from '../utils/seo.js';

const base = import.meta.env.BASE_URL;
---

<Layout 
  title="About Us — QR Guy" 
  description="Learn about QR Guy (qrguy), the developer-grade, 100% client-side, open-source QR and barcode maker online workspace built for privacy."
  canonicalUrl={getCanonical('/about-us')}
>
  <Header />

  <main class="flex-grow relative bg-canvas py-16 md:py-24 px-6 md:px-8 font-sans">
    <!-- Premium Mesh Gradient Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none -z-10" aria-hidden="true">
      <div class="absolute top-[-20%] left-[-10%] w-[60%] h-[60%] rounded-full bg-link/10 dark:bg-link/5 blur-[100px] md:blur-[130px] animate-mesh-1"></div>
      <div class="absolute top-[10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-violet/10 dark:bg-violet/5 blur-[100px] md:blur-[120px] animate-mesh-2"></div>
    </div>

    <div class="max-w-[800px] mx-auto">
      <!-- Tag / Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border border-hairline bg-canvas-soft-2 text-[11px] font-mono text-body">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-violet animate-pulse"></span>
        Our Core Philosophy
      </div>

      <!-- Main Heading -->
      <h1 class="text-4xl sm:text-5xl font-semibold text-ink tracking-tight mb-8 leading-[1.1] max-w-2xl select-none">
        We believe web tools should be fast, open, and strictly private.
      </h1>

      <!-- Lead paragraph -->
      <p class="text-lg text-body font-light leading-relaxed mb-12">
        QR Guy (also known as <strong>qrguy</strong>) started with a simple observation: generating a QR code or scanning a barcode shouldn't require creating an account, paying for SVG files, or letting third-party servers track your data. We built QR Guy as a local-first web application to put professional tools in your hands, free of clutter and corporate tracking.
      </p>

      <!-- Grid of Stats/Values -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-16">
        <div class="p-6 rounded-lg border border-hairline bg-canvas-soft-2/50 backdrop-blur-sm shadow-level-1">
          <span class="text-2xl font-semibold text-ink font-mono block mb-2">100%</span>
          <span class="text-xs font-mono text-mute uppercase tracking-wider block mb-1">Client-Side</span>
          <p class="text-xs text-body leading-relaxed">All operations run in your browser sandbox. Your inputs never touch a server.</p>
        </div>

        <div class="p-6 rounded-lg border border-hairline bg-canvas-soft-2/50 backdrop-blur-sm shadow-level-1">
          <span class="text-2xl font-semibold text-ink font-mono block mb-2">0</span>
          <span class="text-xs font-mono text-mute uppercase tracking-wider block mb-1">Paywalls</span>
          <p class="text-xs text-body leading-relaxed">Export vector SVGs and high-res images completely free. No subscriptions, no ads.</p>
        </div>

        <div class="p-6 rounded-lg border border-hairline bg-canvas-soft-2/50 backdrop-blur-sm shadow-level-1">
          <span class="text-2xl font-semibold text-ink font-mono block mb-2">Open</span>
          <span class="text-xs font-mono text-mute uppercase tracking-wider block mb-1">Source</span>
          <p class="text-xs text-body leading-relaxed">Built with standard open-source libraries. Auditable, customizable, and secure.</p>
        </div>
      </div>

      <!-- Story Section -->
      <div class="space-y-8 text-sm text-body leading-relaxed">
        <h2 class="text-xl font-semibold text-ink tracking-tight border-b border-hairline pb-2">The Tech Behind the App</h2>
        
        <p>
          QR Guy utilizes modern web APIs and robust libraries to perform fast rendering in real-time. By leveraging libraries like <a href="https://github.com/kozakdenys/qr-code-styling" target="_blank" rel="noopener noreferrer" class="text-link hover:underline">qr-code-styling</a> and <a href="https://github.com/mebjas/html5-qrcode" target="_blank" rel="noopener noreferrer" class="text-link hover:underline">html5-qrcode</a>, the app supports high ECL (Error Correction Level) settings, customizable linear or radial gradients, nested branding logos, and camera feeds directly inside the browser.
        </p>

        <p>
          Because we rely on Astro as our base static frame and Tailwind CSS for layouts, the page weight remains incredibly small. This ensures that the page loads instantly, works offline under static caching, and looks crisp on everything from 4K developer monitors to low-end mobile cameras.
        </p>

        <h2 class="text-xl font-semibold text-ink tracking-tight border-b border-hairline pb-2 pt-4">Get Involved</h2>
        
        <p>
          QR Guy is entirely open-source and welcomes community contributions. Whether you'd like to implement new formats (like Aztec, PDF417, or DataMatrix generation), add translation layouts, or optimize scanning speed, you can view, fork, and star the repository on GitHub.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a 
            href="https://github.com/Aftab016/qr-guy.com" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="inline-flex items-center justify-center gap-2 px-6 h-11 text-xs font-semibold rounded-md border border-hairline bg-canvas hover:bg-canvas-soft-2 text-ink active:scale-98 transition-[transform,background-color] duration-150 cursor-pointer w-full sm:w-auto"
          >
            <svg class="w-4 h-4 fill-current" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
            Fork on GitHub
          </a>
          <a 
            href={`${base}#generator`} 
            class="inline-flex items-center justify-center px-6 h-11 text-xs font-semibold rounded-md bg-primary text-on-primary hover:opacity-90 active:scale-98 transition-[transform,opacity] duration-150 cursor-pointer w-full sm:w-auto"
          >
            Start Creating QR Codes
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
