---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCanonical } from '../utils/seo.js';
---

<Layout 
  title="Contact Us — QR Guy" 
  description="Get in touch with the QR Guy team. Submit suggestions, bug reports, or query about client-side QR generation."
  canonicalUrl={getCanonical('/contact-us')}
>
  <Header />

  <main class="flex-grow relative bg-canvas py-16 md:py-24 px-6 md:px-8 font-sans">
    <!-- Premium Mesh Gradient Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none -z-10" aria-hidden="true">
      <div class="absolute bottom-[-20%] left-[-10%] w-[55%] h-[60%] rounded-full bg-cyan/10 dark:bg-cyan/5 blur-[100px] md:blur-[130px] animate-mesh-1"></div>
      <div class="absolute top-[-10%] right-[-10%] w-[60%] h-[60%] rounded-full bg-violet/10 dark:bg-violet/5 blur-[100px] md:blur-[130px] animate-mesh-3"></div>
    </div>

    <div class="max-w-[1200px] mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-start">
        
        <!-- Left Column: Title & Info Cards -->
        <div class="md:col-span-5 space-y-8">
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border border-hairline bg-canvas-soft-2 text-[11px] font-mono text-body">
              <span class="inline-block w-1.5 h-1.5 rounded-full bg-cyan animate-pulse"></span>
              Support & Collaboration
            </div>
            <h1 class="text-4xl sm:text-5xl font-semibold text-ink tracking-tight mb-4 leading-[1.1] select-none">
              Contact our team
            </h1>
            <p class="text-sm text-body leading-relaxed max-w-sm">
              Have questions about QR Guy? Found a bug in our scanner? Want to propose an integration? Reach out and we'll reply shortly.
            </p>
          </div>

          <div class="space-y-4">
            <!-- Github issue tracker -->
            <a 
              href="https://github.com/Aftab016/qr-guy.com/issues" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="group flex items-start gap-4 p-5 rounded-lg border border-hairline bg-canvas-soft/40 hover:bg-canvas-soft-2/60 transition-all duration-200 shadow-level-1"
            >
              <div class="w-10 h-10 rounded-md border border-hairline bg-canvas flex items-center justify-center text-ink shrink-0 group-hover:scale-105 transition-transform">
                <svg class="w-5 h-5 fill-current" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
              </div>
              <div class="space-y-1">
                <h3 class="text-sm font-semibold text-ink group-hover:text-primary transition-colors">GitHub Issue Tracker</h3>
                <p class="text-xs text-mute leading-relaxed">Report bugs, submit feature requests, or browse the open code issues directly.</p>
              </div>
            </a>
          </div>
        </div>

        <!-- Right Column: Interactive Form Card -->
        <div class="md:col-span-7 bg-canvas-soft border border-hairline rounded-xl p-6 md:p-8 shadow-level-3 relative overflow-hidden">
          
          <!-- Successful Send Panel (Hidden by default) -->
          <div id="contact-success" class="absolute inset-0 bg-canvas/95 backdrop-blur-md z-10 flex flex-col items-center justify-center text-center p-8 hidden opacity-0 transition-opacity duration-300">
            <div class="w-12 h-12 rounded-full bg-link-bg-soft border border-link/20 flex items-center justify-center text-link mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
            </div>
            <h3 class="text-lg font-semibold text-ink mb-2">Message Sent Successfully!</h3>
            <p class="text-xs text-body leading-relaxed max-w-sm mb-6">
              Thank you for contacting us. We have received your inquiry and will get back to you shortly.
            </p>
            <button 
              id="btn-reset-form"
              class="inline-flex items-center justify-center px-5 h-9 text-xs font-semibold rounded-md border border-hairline bg-canvas hover:bg-canvas-soft-2 text-ink cursor-pointer active:scale-98 transition-transform"
            >
              Send Another Message
            </button>
          </div>

          <!-- The HTML Form -->
          <form id="contact-form" class="space-y-5">
            <!-- Web3Forms Config -->
            <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || ""} />
            <input type="hidden" name="from_name" value="QR Guy Contact Form" />
            <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="space-y-1.5">
                <label for="contact-name" class="block text-xs font-semibold text-ink font-mono uppercase tracking-wider">Your Name</label>
                <input 
                  type="text" 
                  id="contact-name" 
                  name="name"
                  required 
                  placeholder="John Doe" 
                  class="w-full px-3 py-2 text-xs border border-hairline rounded bg-canvas font-sans focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/20 text-ink"
                />
              </div>
              <div class="space-y-1.5">
                <label for="contact-email" class="block text-xs font-semibold text-ink font-mono uppercase tracking-wider">Email Address</label>
                <input 
                  type="email" 
                  id="contact-email" 
                  name="email"
                  required 
                  placeholder="john@example.com" 
                  class="w-full px-3 py-2 text-xs border border-hairline rounded bg-canvas font-sans focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/20 text-ink"
                />
              </div>
            </div>

            <div class="space-y-1.5">
              <label for="contact-subject" class="block text-xs font-semibold text-ink font-mono uppercase tracking-wider">Subject</label>
              <input 
                type="text" 
                id="contact-subject" 
                name="subject"
                required 
                placeholder="Feedback about the generator..." 
                class="w-full px-3 py-2 text-xs border border-hairline rounded bg-canvas font-sans focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/20 text-ink"
              />
            </div>

            <div class="space-y-1.5">
              <label for="contact-message" class="block text-xs font-semibold text-ink font-mono uppercase tracking-wider">Message</label>
              <textarea 
                id="contact-message" 
                name="message"
                required 
                rows="6" 
                placeholder="Tell us what you have in mind..." 
                class="w-full px-3 py-2 text-xs border border-hairline rounded bg-canvas font-sans focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/20 text-ink resize-y"
              ></textarea>
            </div>

            <button 
              type="submit" 
              class="w-full sm:w-auto inline-flex items-center justify-center px-6 h-10 text-xs font-semibold rounded-md bg-primary text-on-primary hover:opacity-90 active:scale-98 transition-[opacity,transform] duration-150 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary shadow-level-2"
            >
              Submit Inquiry
            </button>
          </form>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successPanel = document.getElementById('contact-success') as HTMLElement | null;
  const resetBtn = document.getElementById('btn-reset-form') as HTMLButtonElement | null;
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  if (form && successPanel && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Prevent double submissions
      submitBtn.disabled = true;
      const originalBtnText = submitBtn.innerHTML;
      submitBtn.innerHTML = `
        <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Sending...
      `;
      
      try {
        const formData = new FormData(form);
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData
        });
        
        const result = await response.json();
        
        if (response.status === 200 && result.success) {
          successPanel.classList.remove('hidden');
          setTimeout(() => {
            successPanel.classList.remove('opacity-0');
          }, 10);
          form.reset();
        } else {
          alert(result.message || 'Something went wrong. Please try again or use GitHub Issues.');
        }
      } catch (err) {
        alert('Failed to send message. Please check your internet connection or use GitHub Issues.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalBtnText;
      }
    });
  }

  if (resetBtn && successPanel) {
    resetBtn.addEventListener('click', () => {
      successPanel.classList.add('opacity-0');
      setTimeout(() => {
        successPanel.classList.add('hidden');
      }, 300);
    });
  }
</script>
